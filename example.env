# Copy this file to .env before running docker compose.

# PostgreSQL used by the backend through Docker DNS.
POSTGRES_USER=git_web_review
POSTGRES_PASSWORD=git_web_review
POSTGRES_DB=git_web_review

# Redis is used internally through Docker DNS and is not exposed on the host.

# Host ports. The backend listens on 3000 inside Docker but is exposed on 3005.
BACKEND_PORT=3005
FRONTEND_PORT=5173
WEBSOCKET_RELAY_PORT=3001

# Public URLs used by browser-side code.
FRONTEND_ORIGIN=http://localhost:5173
PUBLIC_BACKEND_URL=http://localhost:3005
PUBLIC_FRONTEND_URL=http://localhost:5173
PUBLIC_WEBSOCKET_URL=ws://localhost:3001

# Optional HTTP Host allowlists. Leave empty to keep framework defaults/no filtering.
# Use comma-separated hosts; use * to allow every host.
FRONTEND_ALLOWED_HOSTS=
BACKEND_ALLOWED_HOSTS=

# Bootstrap admin emails. Comma-separated list; matching users are promoted to ADMIN on login.
ADMINS=admin@company.tld,review-admin@company.tld

# Max uploaded profile image size in bytes.
PROFILE_IMAGE_MAX_BYTES=1048576

# Firebase Admin credentials are mounted from ./secrets/firebase-service-account.json.
# Keep this path aligned with docker-compose.yml.
GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/firebase-service-account.json
FIREBASE_PROJECT_ID=

# Firebase web app config for the future frontend OAuth flow.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_STORAGE_BUCKET=

# IRC relay config.
IRC_DRY_RUN=true
IRC_HOST=irc.company.tld
IRC_PORT=6697
IRC_TLS=true
IRC_NICK=git-web-review
IRC_USERNAME=git-web-review
IRC_REALNAME=git-web-review notification relay
IRC_PASSWORD=

# Email relay config.
EMAIL_DRY_RUN=true
SMTP_HOST=smtp.company.tld
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=git-web-review@company.tld
